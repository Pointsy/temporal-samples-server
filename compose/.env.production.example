COMPOSE_PROJECT_NAME=temporal-prod

POSTGRESQL_VERSION=17.4
OPENSEARCH_VERSION=2.19.1
TEMPORAL_VERSION=1.30.1
TEMPORAL_ADMINTOOLS_VERSION=1.30.1
TEMPORAL_UI_VERSION=2.34.0
PROMETHEUS_VERSION=v3.2.1
GRAFANA_VERSION=11.5.2
POSTGRES_EXPORTER_VERSION=v0.17.1

POSTGRES_DB=temporal
POSTGRES_USER=temporal
POSTGRES_PASSWORD=replace-with-a-strong-postgres-password

OPENSEARCH_CLUSTER_NAME=temporal-visibility
OPENSEARCH_JAVA_OPTS=-Xms1g -Xmx1g
OPENSEARCH_DISK_WATERMARK_LOW=15gb
OPENSEARCH_DISK_WATERMARK_HIGH=10gb
OPENSEARCH_DISK_WATERMARK_FLOOD=5gb
ES_VISIBILITY_INDEX=temporal_visibility_v1_prod

TEMPORAL_DEFAULT_NAMESPACE=default
TEMPORAL_LOG_LEVEL=warn
TEMPORAL_NUM_HISTORY_SHARDS=512
TEMPORAL_SQL_MAX_CONNS=40
TEMPORAL_SQL_MAX_IDLE_CONNS=20
TEMPORAL_SQL_VIS_MAX_CONNS=20
TEMPORAL_SQL_VIS_MAX_IDLE_CONNS=10

TEMPORAL_BIND_ADDRESS=127.0.0.1
TEMPORAL_GRPC_PORT=7233
TEMPORAL_UI_BIND_ADDRESS=127.0.0.1
TEMPORAL_UI_PORT=8080
TEMPORAL_UI_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION_TIME=15d

GRAFANA_BIND_ADDRESS=127.0.0.1
GRAFANA_PORT=8085
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=replace-with-a-strong-grafana-password
